{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Beta": {
    "RegistrationOpen": true
  },
  "Mail": {
    "Provider": "",
    "BrevoApiKey": "",
    "SenderEmail": "noreply@sentys.fr",
    "SenderName": "Sentys",
    "SupportEmail": "support@sentys.fr"
  },
  "IpRateLimiting": {
    "EnableEndpointRateLimiting": true,
    "StackBlockedRequests": false,
    "RealIpHeader": "X-Real-IP",
    "ClientIdHeader": "X-ClientId",
    "HttpStatusCode": 429,
    "GeneralRules": [
      {
        "Endpoint": "POST:/api/submissions",
        "Period": "1m",
        "Limit": 10
      },
      {
        "Endpoint": "POST:/api/auth/register",
        "Period": "1h",
        "Limit": 5
      },
      {
        "Endpoint": "POST:/api/auth/forgot-password",
        "Period": "1h",
        "Limit": 5
      },
      {
        "Endpoint": "POST:/api/invites/redeem",
        "Period": "1m",
        "Limit": 10
      },
      {
        "Endpoint": "POST:/api/auth/2fa/verify",
        "Period": "1m",
        "Limit": 10
      },
      {
        "Endpoint": "POST:/api/auth/2fa/resend",
        "Period": "1h",
        "Limit": 5
      },
      {
        "Endpoint": "POST:/api/auth/2fa/enable",
        "Period": "1h",
        "Limit": 5
      },
      {
        "Endpoint": "POST:/api/auth/reset-password",
        "Period": "1h",
        "Limit": 10
      }
    ]
  }
}
